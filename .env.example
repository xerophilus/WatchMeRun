# Copy to .env for local dev (production uses EAS environment variables). Only
# public, non-secret values belong here — Expo inlines EXPO_PUBLIC_* into the
# app bundle. No service key, no Spotify secrets.

EXPO_PUBLIC_SUPABASE_URL=https://cmfzwltdllvyrtkrzyhv.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional. Defaults to ${EXPO_PUBLIC_SUPABASE_URL}/functions/v1
# EXPO_PUBLIC_FUNCTIONS_URL=https://your-project-ref.supabase.co/functions/v1

# v2: identity comes from Sign in with Apple — there's no build-time runner id
# or token anymore. Everyone who signs in is a runner; watching is by request.

# Which app the in-app Start button opens after firing the beacon:
#   apple_workout (default, beacon-only) | apple_shortcut | strava
#   | nike_run_club | none
# EXPO_PUBLIC_PREFERRED_RUN_APP=apple_workout
# Name of a watchOS Shortcut that starts an Apple workout. When set, an
# "Apple Watch (Shortcut)" option appears and is launched with the picked
# workout as JSON input so the selection carries over.
# EXPO_PUBLIC_RUN_SHORTCUT_NAME=Start Run
