# Copy to .env and fill in. Only public, non-secret values belong here — Expo
# inlines EXPO_PUBLIC_* into the app bundle. No service key, no Spotify secrets.

EXPO_PUBLIC_SUPABASE_URL=https://cmfzwltdllvyrtkrzyhv.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Ben's seeded runners.id:  select id from runners where handle = 'ben';
EXPO_PUBLIC_RUNNER_ID=86de24d8-8115-4e53-9e73-95be962d227f

# Optional. Defaults to ${EXPO_PUBLIC_SUPABASE_URL}/functions/v1
# EXPO_PUBLIC_FUNCTIONS_URL=https://your-project-ref.supabase.co/functions/v1

# RUNNER-ONLY — leave these UNSET on a watcher's build (e.g. Kenz's).
# Set only on the runner's own device so the in-app "Start my run" button can
# fire the run-event beacon. This is the SAME value the iOS Shortcut carries
# (a row in runner_tokens). With it unset, the app stays read-only.
# EXPO_PUBLIC_RUNNER_TOKEN=your-runner-token
# Which app the Start button opens after firing the beacon:
#   apple_workout (default, beacon-only) | apple_shortcut | strava
#   | nike_run_club | none
# EXPO_PUBLIC_PREFERRED_RUN_APP=apple_workout
# Name of a watchOS Shortcut that starts an Apple workout. When set, an
# "Apple Watch (Shortcut)" option appears and is launched with the picked
# workout as JSON input ({type,label,detail}) so the selection carries over.
# EXPO_PUBLIC_RUN_SHORTCUT_NAME=Start Run
