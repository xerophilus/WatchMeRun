# Edge Function secrets.
#
# SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are injected automatically by the
# platform at runtime — you do NOT need to set them.
#
# There are no other secrets to set. Write auth is handled per-runner via the
# `runner_tokens` table (resolved inside the functions), not via an env var.
# Mint a token for a runner with:
#
#   insert into runner_tokens (runner_id, token, label)
#   values ((select id from runners where handle = 'ben'),
#           '<long-random-string>', 'Ben iPhone Shortcut');
#
# The runner's iOS Shortcut sends that token as `Authorization: Bearer <token>`.
