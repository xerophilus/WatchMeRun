{
  "expo": {
    "name": "Crewd",
    "slug": "watchmerun",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/crewd-icon-1024.png",
    "scheme": "crewd",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.xerophilus.watchmerun",
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "LSApplicationQueriesSchemes": ["strava", "nikerunclub", "shortcuts"],
        "UIBackgroundModes": ["location"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#05060A",
        "foregroundImage": "./assets/images/crewd-icon-1024.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/crewd-favicon-48.png"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      "expo-apple-authentication",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Crewd shares your location with your crew only while you're on a run.",
          "locationAlwaysAndWhenInUsePermission": "Crewd shares your live location with your approved watchers while you run, even when the app is in the background.",
          "isIosBackgroundLocationEnabled": true
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#EAF6F5",
          "dark": {
            "image": "./assets/images/splash-icon.png",
            "backgroundColor": "#00332F"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d8e2c46e-f4d5-4bee-94d5-14622ea08a89"
      }
    },
    "owner": "pittsdev"
  }
}
