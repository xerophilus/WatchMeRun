{
  "expo": {
    "name": "WatchMeRun",
    "slug": "watchmerun",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "watchmerun",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.xerophilus.watchmerun",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#005B57",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#EAF6F5",
          "dark": {
            "image": "./assets/images/splash-icon.png",
            "backgroundColor": "#00332F"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d8e2c46e-f4d5-4bee-94d5-14622ea08a89"
      }
    },
    "owner": "pittsdev"
  }
}
